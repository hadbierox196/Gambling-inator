{
  "version": 2,
  "functions": {
    "api/*.py": {
      "runtime": "vercel-python@0.1.0",
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/analyze", "dest": "/api/analyze.py" },
    { "src": "/api/scan",    "dest": "/api/scan.py" },
    { "src": "/(.*)",        "dest": "/public/$1" },
    { "src": "/",            "dest": "/public/index.html" }
  ]
}
